# openAut NemoClaw skills — shared configuration
# Copy to `config.env` and fill in. Every skill sources this file.
# Keep `config.env` out of git (see .gitignore) — it can hold host names and a webhook URL.

# ----- Target server that will RUN the NemoClaw sandbox (the agent host) -----
# A DGX Spark (GB10) / RTX-class machine with Docker 28+ and Ubuntu 24.04.
SANDBOX_HOST="dgx-spark.local"        # hostname or IP reachable over SSH
SANDBOX_SSH_USER="noname"             # SSH user on the sandbox host
SANDBOX_NAME="openaut"                # NemoClaw sandbox name to create
NEMOCLAW_INSTALL_TAG="v0.0.55"        # pinned NemoClaw release

# ----- Remote inference: Nemotron 3 Super on a SEPARATE machine -----
# The model box (e.g. ASUS Ascent GX10) runs vLLM with an OpenAI-compatible API.
# We reach it over TLS via a reverse proxy in front of vLLM (see nemoclaw-sandbox-policy).
NEMOTRON_HOST="192.168.1.43"          # the model box
NEMOTRON_TLS_PORT="8443"              # TLS reverse-proxy port (NOT vLLM's plaintext 11434)
NEMOTRON_BASE_URL="https://192.168.1.43:8443/v1"
NEMOTRON_MODEL="nemotron-3-super"     # served-model-name on the vLLM box
NEMOTRON_API_KEY=""                   # bearer token the proxy/vLLM expects (leave empty if none)
# Path on the sandbox host to the CA cert that signed the proxy's server cert.
# Required so the sandbox can verify TLS instead of disabling verification.
NEMOTRON_CA_CERT="/etc/nemoclaw/nemotron-ca.pem"

# ----- Communication channel: Microsoft Teams via webhook bridge -----
# The bridge (bridges/teams-webhook) runs near the gateway and maps Teams <-> gateway.
TEAMS_BRIDGE_HOST="127.0.0.1"         # where the bridge listens (loopback if co-located)
TEAMS_BRIDGE_PORT="8790"
# Teams Incoming Webhook URL (gateway -> Teams channel). Create in the Teams channel connectors.
TEAMS_INCOMING_WEBHOOK_URL=""
# Shared secret used to authenticate Teams Outgoing Webhook callbacks (Teams -> bridge).
TEAMS_OUTGOING_SECRET=""
# Bearer token required for local gateway/agent posts to /to-teams.
TEAMS_TO_TEAMS_TOKEN=""
TEAMS_BRIDGE_MAX_BODY_BYTES="65536"

# ----- Data backbone: EMQX MQTT/TLS broker (AI-tier host) -----
EMQX_HOST="192.168.1.10"              # host running EMQX
EMQX_SSH_USER="openaut"               # SSH user on the broker host
EMQX_TLS_PORT="8883"                  # mutual-TLS MQTT listener (NOT plaintext 1883)
# PKI used for broker + edge client certs (generated by mqtt-tls-broker/scripts/gen-certs.sh)
PKI_DIR="./pki"                       # local dir holding ca/, broker/, clients/
MQTT_CA_CERT="${PKI_DIR}/ca/ca.crt"

# ----- Data backbone: TimescaleDB + PostgreSQL (AI-tier host) -----
TSDB_HOST="192.168.1.10"              # host running PostgreSQL/TimescaleDB
TSDB_SSH_USER="openaut"
TSDB_PORT="5432"
TSDB_DB="openaut"                     # database name
TSDB_TS_SCHEMA="telemetry"            # schema for timeseries hypertables
TSDB_INGEST_USER="ingest"             # write user for the MQTT->TSDB consumer
TSDB_AGENT_RO_USER="agent_ro"         # read-only user granted to the energy/manager agents

# ----- Edge: Siemens SIMATIC IOT2050 node -----
EDGE_HOST="192.168.1.50"              # an IOT2050 edge node
EDGE_SSH_USER="root"                  # default IOT2050 admin user
EDGE_NODE_ID="iot2050-ahu-01"         # logical id; becomes MQTT client id + topic prefix
EDGE_SITE="karsamala"                 # site tag used in topics and DB rows
